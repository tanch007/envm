  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "node scripts/update-html-title.js && electron-vite build",
    "build": "electron-builder --config electron-builder.ts --dir ",
    "build:win": "npm run prebuild && electron-builder --config electron-builder.ts --win",
